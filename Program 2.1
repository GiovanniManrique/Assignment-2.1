
using Microsoft.VisualBasic;

Console.WriteLine("1. Add two intergers");
Console.WriteLine("2. Add three decimals");
Console.WriteLine("3. Multiply two floats");
Console.WriteLine("4. Multiply three floats");

Console.Write("Enter your choice: ");

int Choice = Convert.ToInt32(Console.ReadLine());

if (Choice == 1)
{
    Console.WriteLine("Enter first interger");

    int Firstint = Convert.ToInt32(Console.ReadLine());
    Console.WriteLine("Enter second interger");
    int Secondint = Convert.ToInt32(Console.ReadLine());

    int result = Mymath.Add(Firstint, Secondint);

    Console.WriteLine("Your answer is " + result);

}

else if (Choice == 2)
{

    Console.WriteLine("Enter first Decimal");

    Decimal First = Convert.ToDecimal(Console.ReadLine());
    Console.WriteLine("Enter second Decimal");

    Decimal Second = Convert.ToDecimal(Console.ReadLine());
    Console.WriteLine("Enter Third Decimal");
    Decimal Third = Convert.ToDecimal(Console.ReadLine());

    Decimal result = Mymath.Add(First, Second, Third);

    Console.WriteLine("Your answer is " + result);


}

else if (Choice == 3)
{



    Console.WriteLine("Enter first Float");

    float First = Convert.ToSingle(Console.ReadLine());

    Console.WriteLine("Enter second float");

    float Second = Convert.ToSingle(Console.ReadLine());

   float result = Mymath.Multiply(First, Second);

    Console.WriteLine("Your answer is " + result);


}

else
{


    Console.WriteLine("Enter first Float");

    float First = float.Parse(Console.ReadLine());

    Console.WriteLine("Enter second float");

    float Second= float.Parse(Console.ReadLine());

    Console.WriteLine("Enter second Third");

    float Third = float.Parse(Console.ReadLine());

    float result = Mymath.Multiply(First, Second, Third);

    Console.WriteLine("Your answer is " + result);


}
        


class Mymath
{
        
  
public static int Add(int num1, int num2)
{

        return num1 + num2;


 }
        
        
        public static decimal Add(decimal num1, decimal num2, decimal num3)
    {

        return num1 + num2 + num3;


    }


    public static float Multiply(float num1, float num2)
    {

        return num1 * num2;

    }



    public static float Multiply(float num1, float num2, float num3)
    {

        return num1 * num2 * num3;


    }



}